{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assay:sdk_ingest",
  "title": "SDK Ingest Payload",
  "description": "Payload POSTed by the Assay browser SDK to the FastAPI /ingest endpoint.",
  "type": "object",
  "required": ["captured_at", "url", "viewport", "user_agent", "screenshot"],
  "additionalProperties": false,
  "properties": {
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the capture occurred."
    },
    "url": {
      "type": "string",
      "minLength": 1,
      "description": "Full page URL at time of capture."
    },
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "exclusiveMinimum": 0 },
        "height": { "type": "integer", "exclusiveMinimum": 0 }
      },
      "description": "Browser viewport dimensions at time of capture."
    },
    "user_agent": {
      "type": "string",
      "minLength": 1,
      "description": "Browser user agent string."
    },
    "screenshot": {
      "type": "string",
      "minLength": 1,
      "description": "Base64-encoded PNG screenshot."
    },
    "user_comment": {
      "type": ["string", "null"],
      "description": "Optional user-provided context. Null if not provided."
    },
    "metadata": {
      "type": "object",
      "description": "Additional arbitrary metadata. Optional."
    }
  }
}
